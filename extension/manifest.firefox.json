{
  "manifest_version": 3,
  "name": "CF-Police",
  "version": "1.0.3",
  "description": "Codeforces Behavioral Anomaly & Performance Analytics Overlay",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "action": {
    "default_icon": "icons/icon128.png",
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "*://codeforces.com/profile/*",
        "*://codeforces.com/contest/*/standings*"
      ],
      "css": [
        "styles.css"
      ],
      "js": [
        "engine.js",
        "content.js"
      ],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "baseline.json"
      ],
      "matches": [
        "*://codeforces.com/*"
      ]
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "cfpolice@codewithayuu",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": []
      }
    }
  }
}
